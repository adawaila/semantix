# semantix environment configuration
# Copy to .env and fill in values

# ---- Embedding provider ----
# "local" uses sentence-transformers all-MiniLM-L6-v2 (fully offline)
# "openai" uses text-embedding-3-small (requires OPENAI_API_KEY)
EMBED_PROVIDER=local

# OpenAI API key — only required if EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ---- Storage ----
# Directory where collection data is persisted inside the container
DATA_DIR=/data

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Worker ----
# Number of ingestion worker processes
WORKERS=4

# ---- API ----
API_PORT=8000

# ---- Dashboard ----
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
